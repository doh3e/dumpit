OPENAI_API_KEY=sk-your-key-here
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# AWS RDS PostgreSQL 연결 정보
DB_URL=jdbc:postgresql://your-rds-endpoint.rds.amazonaws.com:5432/dumpit?sslmode=require
DB_USERNAME=dumpit_admin
DB_PASSWORD=your-rds-password

# Redis (docker-compose에서는 기본 redis 서비스명을 사용)
REDIS_HOST=redis
REDIS_PORT=6379

# Resend 메일 발송 (없으면 메일 발송 스킵, 문의 저장만 됨)
RESEND_API_KEY=re_your_resend_api_key
# 도메인 인증 전엔 onboarding@resend.dev 만 가능. 인증 후 noreply@dumpit.kr 등 가능
MAIL_FROM=noreply@dumpit.kr
# admin에게 신규 문의 알림 발송될 이메일
ADMIN_NOTIFICATION_EMAIL=dumpitadmin@gmail.com

# Sentry 에러 모니터링
SENTRY_AUTH_TOKEN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_EXCEPTION_RESOLVER_ORDER=-2147483647
SENTRY_MAX_REQUEST_BODY_SIZE=small
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_SENTRY_SEND_DEFAULT_PII=false

# 로그 보존 기간
WITHDRAWN_ACTIVITY_LOG_RETENTION_DAYS=90
WITHDRAWN_AI_USAGE_LOG_RETENTION_DAYS=180
LOG_RETENTION_CLEANUP_CRON=0 30 3 * * *
